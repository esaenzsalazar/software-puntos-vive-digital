# ============================================================
# Puntos Vive Digital — Variables de entorno
# Copie este archivo como .env y complete los valores.
# NUNCA suba .env al repositorio (está en .gitignore).
# ============================================================

# ── DJANGO ──────────────────────────────────────────────────
# Genere una clave segura con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=cambie-esto-por-una-clave-secreta-larga

# False en producción, True en desarrollo local
DJANGO_DEBUG=True

# En producción: el dominio real, sin espacios ni http://
# Ejemplo: pvd.bugalagrande.gov.co,www.pvd.bugalagrande.gov.co
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# En producción: https://pvd.bugalagrande.gov.co
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# ── BASE DE DATOS (Aiven MySQL) ─────────────────────────────
DB_NAME=modeladobd
DB_USER=avnadmin
DB_PASSWORD=
DB_HOST=mysql-3bb67bf0-alcaldiaesteban-d1bc.k.aivencloud.com
DB_PORT=27827

# ── CACHÉ (Redis — solo producción) ─────────────────────────
# En desarrollo déjelo vacío (Django usa memoria interna).
# En producción: redis://127.0.0.1:6379/1
REDIS_URL=
